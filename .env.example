# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by the API server and Drizzle ORM.
DATABASE_URL=postgresql://user:password@localhost:5432/livingsyria

# ── Authentication (Better Auth) ──────────────────────────────────────────────
# Secret used to sign session tokens — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# Public URL of the API server (used by Better Auth for callbacks and CORS).
# In development this is http://localhost:8080; in production set to the
# deployed API URL (e.g. https://api.yourdomain.com).
BETTER_AUTH_URL=http://localhost:8080

# ── API base URL (web app) ─────────────────────────────────────────────────────
# Absolute URL the Next.js web app uses to reach the API server.
# In development: http://localhost:8080
# In production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Cloudflare R2 (object storage) ────────────────────────────────────────────
# Cloudflare account ID (found in the Cloudflare dashboard sidebar).
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 API credentials — create an API token with R2 read/write permissions.
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Name of the R2 bucket used for listing images and other uploads.
R2_BUCKET_NAME=your-bucket-name

# Public base URL for serving objects (set on your R2 bucket or custom domain).
# Example: https://pub-abc123.r2.dev
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ── Google Gemini AI ───────────────────────────────────────────────────────────
# API key for Google Gemini (get one at https://aistudio.google.com/apikey).
GEMINI_API_KEY=your-gemini-api-key

# Optional: override the Gemini API base URL (leave unset to use the default).
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated list of user IDs that have admin privileges.
# Find a user's ID in the database: SELECT id FROM "user" WHERE email = '...';
ADMIN_USER_IDS=user_id_1,user_id_2

# ── Server ────────────────────────────────────────────────────────────────────
# Port the API server listens on. Defaults to 8080 if unset.
PORT=8080

# ── Mobile (Expo) ─────────────────────────────────────────────────────────────
# Public hostname used by the Expo web build to determine the deployment domain.
# In development this is set automatically by the Expo dev server.
EXPO_PUBLIC_DOMAIN=your-app.example.com
